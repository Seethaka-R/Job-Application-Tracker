# ============================================================
# Environment Variables Template for Job Application Tracker
# ============================================================
# Copy this file to ".env" and fill in your actual values.
#   cp .env.example .env
# NEVER commit the real .env file to version control.
# ============================================================

# MongoDB connection string
# Local example : mongodb://localhost:27017/job-tracker
# Atlas example : mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/job-tracker
MONGO_URI=mongodb://localhost:27017/job-tracker

# Secret key used to sign JSON Web Tokens – use a long, random string
JWT_SECRET=your_super_secret_jwt_key_change_me

# Port the Express server listens on (default: 5000)
PORT=5000

# Node environment (development | production | test)
NODE_ENV=development
